{"name": "newwebai-migration", "version": "1.0.0", "description": "NewWebAI 数据库迁移工具 - 从 MongoDB 到 SQL", "main": "migrate_data.js", "scripts": {"test:connection": "node test_sql_connection.js", "migrate": "node migrate_data.js", "migrate:backup": "node migrate_data.js --backup", "migrate:verify": "node test_sql_connection.js && node migrate_data.js --verify", "install:deps": "npm install mongodb mysql2 dotenv"}, "keywords": ["migration", "mongodb", "mysql", "database", "sqlpub"], "author": "NewWebAI Team", "license": "MIT", "dependencies": {"mongodb": "^6.3.0", "mysql2": "^3.6.5", "dotenv": "^16.3.1"}, "devDependencies": {}, "engines": {"node": ">=14.0.0"}, "repository": {"type": "git", "url": "https://github.com/Apollohzl/NewWebAI.git"}, "bugs": {"url": "https://github.com/Apollohzl/NewWebAI/issues"}, "homepage": "https://github.com/Apollohzl/NewWebAI#readme"}